<Page x:Class="CVGeneratorApp.PreviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:templates="clr-namespace:CVGeneratorApp.Templates"
      Background="#F3F4F6" Title="PreviewPage" FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="ExportButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#059669"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid x:Name="pnlSelection" Visibility="Visible" Background="White">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Choose a CV Template" FontSize="28" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Select a design to preview your generated CV." FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <Button x:Name="btnSelectTemp1" Width="220" Height="300" Margin="15" Cursor="Hand" Click="btnSelectTemp1_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#F9FAFB" BorderBrush="#3B82F6" BorderThickness="2" CornerRadius="10" Padding="20">
                                    <StackPanel VerticalAlignment="Center">

                                        <Border Width="90" Height="127" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="3" Margin="0,0,0,20" HorizontalAlignment="Center" ClipToBounds="True">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.15" Direction="270"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Background="#1E293B">
                                                    <StackPanel Margin="4,8,4,4">
                                                        <Border Width="24" Height="24" CornerRadius="12" Background="#334155" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                                        <Rectangle Height="2" Fill="#3B82F6" Width="10" HorizontalAlignment="Left" Margin="0,0,0,4"/>
                                                        <Rectangle Height="2" Fill="#64748B" Margin="0,0,0,2"/>
                                                        <Rectangle Height="2" Fill="#64748B" Margin="0,0,0,2"/>
                                                        <Rectangle Height="2" Fill="#64748B" Margin="0,0,0,6"/>
                                                        <Rectangle Height="2" Fill="#3B82F6" Width="10" HorizontalAlignment="Left" Margin="0,0,0,4"/>
                                                        <Rectangle Height="2" Fill="#64748B" Margin="0,0,0,2"/>
                                                        <Rectangle Height="2" Fill="#64748B" Margin="0,0,0,2"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Background="White">
                                                    <StackPanel Margin="6,8,6,4">
                                                        <Rectangle Height="4" Fill="#1E293B" Width="40" HorizontalAlignment="Left" Margin="0,0,0,2"/>
                                                        <Rectangle Height="2" Fill="#3B82F6" Width="25" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                                        <Rectangle Height="3" Fill="#1E293B" Width="20" HorizontalAlignment="Left" Margin="0,0,0,2"/>
                                                        <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,3"/>
                                                        <Rectangle Height="2" Fill="#94A3B8" Margin="0,0,0,2"/>
                                                        <Rectangle Height="2" Fill="#94A3B8" Width="30" HorizontalAlignment="Left" Margin="0,0,0,6"/>

                                                        <Rectangle Height="3" Fill="#1E293B" Width="20" HorizontalAlignment="Left" Margin="0,0,0,2"/>
                                                        <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,3"/>
                                                        <Rectangle Height="2" Fill="#94A3B8" Margin="0,0,0,2"/>
                                                        <Rectangle Height="2" Fill="#94A3B8" Margin="0,0,0,2"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="Modern Professional" FontSize="16" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock Text="Two-column ATS-friendly design." FontSize="13" Foreground="#6B7280" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Border Width="220" Height="300" Margin="15" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="2" CornerRadius="10" Padding="20" Opacity="0.6">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="🔒" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <TextBlock Text="Classic Minimal" FontSize="16" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="More templates coming soon..." FontSize="13" Foreground="#6B7280" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid x:Name="pnlPreview" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="30,15" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Preview &amp; Export" FontSize="24" FontWeight="Bold" Foreground="#1F2937"/>
                        <TextBlock Text="Review your CV design before exporting to PDF." FontSize="14" Foreground="#6B7280" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button x:Name="btnExportPDF" Content="💾 Export as PDF" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Style="{StaticResource ExportButtonStyle}" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="btnExportPDF_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#F9FAFB" Padding="20,10" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid>
                    <Button x:Name="btnBack" Content="← Back to Templates" HorizontalAlignment="Left" VerticalAlignment="Center" 
                            Background="Transparent" BorderThickness="0" Foreground="#3B82F6" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="btnBack_Click"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Zoom:" VerticalAlignment="Center" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <Slider x:Name="zoomSlider" Minimum="0.2" Maximum="2.0" Value="1.0" Width="150" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ElementName=zoomSlider, Path=Value, StringFormat={}{0:P0}}" VerticalAlignment="Center" Foreground="#4B5563" FontWeight="Bold" Margin="10,0,0,0" Width="45"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer x:Name="scrollArea" Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#E5E7EB">
                <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">

                    <Border.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ElementName=zoomSlider, Path=Value}" ScaleY="{Binding ElementName=zoomSlider, Path=Value}"/>
                    </Border.LayoutTransform>

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2" Direction="270"/>
                    </Border.Effect>

                    <ContentControl x:Name="TemplateContainer"/>

                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>