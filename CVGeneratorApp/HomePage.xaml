<Page x:Class="CVGeneratorApp.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Home"
      Background="Transparent"
      FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="CreateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="20">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="35,0,10,0"/>

                                <TextBlock x:Name="placeholder" 
                                           Text="Search your saved CVs..." 
                                           Foreground="#AAAAAA" 
                                           FontStyle="Italic"
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Left" 
                                           Margin="35,0,0,0" 
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>

                                <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" 
                                           Foreground="#888888" VerticalAlignment="Center" 
                                           HorizontalAlignment="Left" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CVCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="320"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#EEEEEE"/>
                                <Setter Property="Foreground" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Welcome back, Sandun!" FontSize="28" FontWeight="Bold" Foreground="#333333"/>
                <TextBlock Text="Ready to build another professional CV?" Foreground="#888888" FontSize="14" Margin="0,5,0,0"/>
            </StackPanel>

            <Button x:Name="btnCreateNew" 
                    Style="{StaticResource CreateButtonStyle}" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center"
                    Click="btnCreateNew_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+ " FontSize="18" Margin="0,0,5,0"/>
                    <TextBlock Text="Create New CV" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,25">
            <TextBox Style="{StaticResource SearchBoxStyle}" Width="350" HorizontalAlignment="Left"/>
        </Grid>

        <TextBlock Grid.Row="2" Text="My Saved CVs" FontSize="20" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="pnlCVList">

                <Border Style="{StaticResource CVCardStyle}">
                    <Grid>
                        <StackPanel>
                            <Border Background="#F0F0F0" Height="140" CornerRadius="5">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.2"/>
                            </Border>

                            <TextBlock Text="Software Engineer v1" FontWeight="Bold" FontSize="16" Margin="0,12,0,2" Foreground="#333333"/>
                            <TextBlock Text="Updated: 2026-04-27" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,10"/>

                            <TextBlock Text="Profile Completion: 85%" FontSize="11" Foreground="#555555" Margin="0,5,0,3"/>
                            <ProgressBar Value="85" Height="6" Background="#EEEEEE" Foreground="#4CAF50" BorderThickness="0">
                                <ProgressBar.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </ProgressBar.Resources>
                            </ProgressBar>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                                <Button Style="{StaticResource CardActionButton}" Content="&#xE70F;" ToolTip="Edit CV"/>
                                <Button Style="{StaticResource CardActionButton}" Content="&#xE896;" ToolTip="Download PDF"/>
                                <Button Style="{StaticResource CardActionButton}" Content="&#xE74D;" ToolTip="Delete CV"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CVCardStyle}">
                    <Grid>
                        <StackPanel>
                            <Border Background="#F0F0F0" Height="140" CornerRadius="5">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.2"/>
                            </Border>

                            <TextBlock Text="Multimedia Designer" FontWeight="Bold" FontSize="16" Margin="0,12,0,2" Foreground="#333333"/>
                            <TextBlock Text="Updated: 2026-04-20" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,10"/>

                            <TextBlock Text="Profile Completion: 40%" FontSize="11" Foreground="#555555" Margin="0,5,0,3"/>
                            <ProgressBar Value="40" Height="6" Background="#EEEEEE" Foreground="#FF9800" BorderThickness="0">
                                <ProgressBar.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </ProgressBar.Resources>
                            </ProgressBar>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                                <Button Style="{StaticResource CardActionButton}" Content="&#xE70F;" ToolTip="Edit CV"/>
                                <Button Style="{StaticResource CardActionButton}" Content="&#xE896;" ToolTip="Download PDF"/>
                                <Button Style="{StaticResource CardActionButton}" Content="&#xE74D;" ToolTip="Delete CV"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Page>