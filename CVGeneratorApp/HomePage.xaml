<Page x:Class="CVGeneratorApp.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Home"
      Background="Transparent">

    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="My Saved CVs" FontSize="28" FontWeight="Bold" Foreground="#333333"/>
            <Separator Margin="0,10,0,20" Background="#DDDDDD"/>

            <TextBlock Text="You haven't created any CVs yet. Click 'Edit CV Details' to start!" 
                       Foreground="#888888" FontSize="16" FontStyle="Italic" Margin="0,50,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>