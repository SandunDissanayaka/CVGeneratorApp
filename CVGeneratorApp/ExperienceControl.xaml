<UserControl x:Class="CVGeneratorApp.ExperienceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White" FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Job Title" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="cmbJobTitle" IsEditable="True" Style="{StaticResource ModernInput}">
                <ComboBoxItem Content="Software Engineer"/>
                <ComboBoxItem Content="Associate Software Engineer"/>
                <ComboBoxItem Content="Trainee / Intern"/>
                <ComboBoxItem Content="Full Stack Developer"/>
                <ComboBoxItem Content="UI/UX Designer"/>
                <ComboBoxItem Content="Quality Assurance (QA) Engineer"/>
                <ComboBoxItem Content="System Administrator"/>
            </ComboBox>

            <TextBlock Text="Company Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtCompany" Padding="10,5" Height="38" Margin="0,0,0,15"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Duration (e.g. Jan 2024 - Present)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtDuration" Padding="10,5" Height="38" Margin="0,0,0,15"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Location" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtLocation" Padding="10,5" Height="38" Margin="0,0,0,15" Tag="e.g. Colombo, Sri Lanka"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Main Responsibilities / Key Achievements" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtResponsibilities" Padding="10" Height="80" Margin="0,0,0,15" 
                     AcceptsReturn="True" VerticalContentAlignment="Top" TextWrapping="Wrap"
                     Tag="Tip: Use bullet points for a better look!"/>
        </StackPanel>

        <Button x:Name="btnAddExperience" Grid.Row="1" Content="+ Add Experience" 
                HorizontalAlignment="Left" Padding="20,10" Margin="0,5,0,20"
                Background="Transparent" BorderBrush="#007ACC" Foreground="#007ACC" 
                FontWeight="Bold" Cursor="Hand" Click="btnAddExperience_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="lstExperience">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F9F9F9" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#EEEEEE" BorderThickness="1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="{Binding JobTitle}" FontWeight="Bold" FontSize="15" Foreground="#333333"/>
                                    <TextBlock Text="{Binding Company}" FontSize="13" Foreground="#007ACC" Margin="0,2,0,2"/>
                                    <TextBlock Text="{Binding DurationLocation}" FontSize="12" Foreground="#888888" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Responsibilities}" FontSize="13" Foreground="#555555" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Content="Remove" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        Background="Transparent" Foreground="#FF4444" BorderThickness="0" Cursor="Hand"
                                        Click="RemoveExperience_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>